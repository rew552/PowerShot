<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title=">_ PowerShot 3.2"
    MinWidth="800" MinHeight="600"
    Width="1100" Height="650"
    WindowStartupLocation="CenterScreen"
    Background="Transparent"
    AllowsTransparency="True"
    WindowStyle="None"
    Topmost="True">

    <Window.Resources>
        <!-- Shared dark theme styles -->
        <SolidColorBrush x:Key="BgPrimary" Color="#252526"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BgTertiary" Color="#2D2D30"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="FgPrimary" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="FgSecondary" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#50A6E8"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#6AB5EF"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#F44747"/>

        <!-- TextBox style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#F1F1F1"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="Black"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Label style -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- Custom ScrollBar style -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Style>
                                            <Style TargetType="{x:Type Thumb}">
                                                <Setter Property="OverridesDefaultStyle" Value="true"/>
                                                <Setter Property="IsTabStop" Value="false"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                                            <Border x:Name="rectangle" Background="#3E3E42" CornerRadius="4" 
                                                                    Width="6" Height="{TemplateBinding Height}" 
                                                                    SnapsToDevicePixels="True" Margin="1,0"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="true">
                                                                    <Setter TargetName="rectangle" Property="Background" Value="#999999" />
                                                                </Trigger>
                                                                <Trigger Property="IsDragging" Value="true">
                                                                    <Setter TargetName="rectangle" Property="Background" Value="#CCCCCC" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="Height" Value="8"/>
                                <Setter Property="MinHeight" Value="8"/>
                                <Setter TargetName="Bg" Property="Height" Value="8"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter TargetName="Thumb" Property="Style">
                                    <Setter.Value>
                                        <Style TargetType="{x:Type Thumb}">
                                            <Setter Property="OverridesDefaultStyle" Value="true"/>
                                            <Setter Property="IsTabStop" Value="false"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                                        <Border x:Name="rectangle" Background="#3E3E42" CornerRadius="4" 
                                                                Height="6" Width="{TemplateBinding Width}" 
                                                                SnapsToDevicePixels="True" Margin="0,1"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="true">
                                                                <Setter TargetName="rectangle" Property="Background" Value="#999999" />
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="true">
                                                                <Setter TargetName="rectangle" Property="Background" Value="#CCCCCC" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1C97EA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nav Button style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- GridView Header style -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI, Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0,0,1,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Title Bar Button style -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings Tool Button style -->
        <Style x:Key="SettingsToolButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3F3F46"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox Style -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- TabControl Style -->
        <Style x:Key="DarkTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- TabItem Style -->
        <Style x:Key="DarkTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4,4,0,0" Margin="0,0,2,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="#F1F1F1"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="#F1F1F1"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#252526" CornerRadius="10" BorderBrush="#3F3F46" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid x:Name="TitleBarGrid" Grid.Row="0" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                    <TextBlock Text=">_ " Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="PowerShot 3.2" Foreground="#AAAAAA" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="SettingsToolButton" 
                            Width="45" Content="⚙" FontSize="14" 
                            Style="{StaticResource SettingsToolButtonStyle}" VerticalAlignment="Stretch"/>
                    <Button x:Name="CloseToolButton" 
                            Width="45" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" 
                            Style="{StaticResource TitleBarButtonStyle}" VerticalAlignment="Stretch"/>
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="8,0,8,8">
                <Grid.Resources>
                     <!-- Override ListBox selection to use our lighter blue -->
                     <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3D50A6E8"/>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="65*"/>
                    <ColumnDefinition Width="35*"/>
                </Grid.ColumnDefinitions>
        
                <!-- ===== LEFT COLUMN: Image Preview ===== -->
                <Border Grid.Column="0"
                        Background="#1E1E1E"
                        BorderBrush="#3F3F46"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="0,0,8,0">
                    <Viewbox Stretch="Uniform">
                        <Grid>
                            <Image x:Name="PreviewImage" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <!-- Background="#01000000" is almost transparent but catches mouse events -->
                            <Canvas x:Name="CropCanvas" Background="#01000000" Visibility="Collapsed">
                                <Rectangle x:Name="CropSelectionRect" 
                                           Stroke="DeepSkyBlue" StrokeThickness="2" StrokeDashArray="4 4" 
                                           Fill="#33007ACC" Visibility="Collapsed"/>
                            </Canvas>
                        </Grid>
                    </Viewbox>
                </Border>
        
                <!-- ===== RIGHT COLUMN: Explorer + Form ===== -->
                <TabControl Grid.Column="1" Style="{StaticResource DarkTabControl}" Margin="8,4,0,0">
                    <TabItem Header="💾 保存" Style="{StaticResource DarkTabItem}">
                        <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Row 1: File Explorer + Buttons -->
                        <RowDefinition Height="Auto"/>   <!-- Row 2: Back + Address bar -->
                        <RowDefinition Height="Auto"/>   <!-- New Folder Panel -->
                        <RowDefinition Height="*"/>      <!-- Explorer ListView -->
                        <RowDefinition Height="Auto"/>   <!-- Input Form -->
                    </Grid.RowDefinitions>
        
                    <!-- Row 1: Title and Action Buttons -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Text="File Explorer" 
                                   Foreground="#888888" 
                                   FontFamily="Yu Gothic UI, Segoe UI"
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"/>
                        
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button x:Name="NewFolderButton" Style="{StaticResource SecondaryButton}" Content="📁作成" ToolTip="新しいフォルダを作成" Padding="22,4" Margin="0,0,8,0"/>
                            <Button x:Name="DeleteButton" Style="{StaticResource SecondaryButton}" Content="🗑️ 削除" Foreground="#F44747" ToolTip="選択した項目を削除" Padding="22,4" IsEnabled="False"/>
                        </StackPanel>
                    </Grid>
        
                    <!-- Row 2: Navigation Bar -->
                    <DockPanel Grid.Row="1" Margin="0,0,0,8">
                        <Button x:Name="BackButton"
                                Style="{StaticResource NavButton}"
                                Content="&#xE72B;"
                                ToolTip="親フォルダへ戻る"
                                DockPanel.Dock="Left"
                                Margin="0,0,8,0"/>
                        
                        <Border Background="#1E1E1E"
                                BorderBrush="#3F3F46"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="8,4">
                            <TextBlock x:Name="PathDisplay"
                                       Foreground="#AAAAAA"
                                       FontFamily="Yu Gothic UI, Segoe UI"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Text=".\"/>
                        </Border>
                    </DockPanel>
        
                    <!-- New Folder Inline Dialog -->
                    <Border x:Name="NewFolderPanel" Grid.Row="2" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" Padding="8" Margin="0,0,0,6" Visibility="Collapsed">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                <Button x:Name="CreateFolderButton" Style="{StaticResource PrimaryButton}" Content="作成" Padding="20,6" Margin="0,0,8,0"/>
                                <Button x:Name="CancelFolderButton" Style="{StaticResource SecondaryButton}" Content="キャンセル" Padding="20,6" IsCancel="True"/>
                            </StackPanel>
                            <TextBox x:Name="NewFolderNameTextBox" Style="{StaticResource DarkTextBox}" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
        
                    <ListView x:Name="ExplorerListView"
                              Grid.Row="3"
                              Background="#1E1E1E"
                              BorderBrush="{StaticResource BorderBrush}"
                              BorderThickness="1"
                              Foreground="#F1F1F1"
                              FontFamily="Yu Gothic UI, Segoe UI"
                              FontSize="13"
                              Margin="0,0,0,6"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              VirtualizingPanel.IsVirtualizing="False"
                              SelectionMode="Extended">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value="#F1F1F1"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="2">
                                                <GridViewRowPresenter VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2A2D2E"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#094771"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="名前" Width="350">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="6,4">
                                                <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="更新日時" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LastModified, StringFormat='yyyy/MM/dd HH:mm'}" Foreground="#AAAAAA" FontSize="11" Margin="4,2" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
        
                    <!-- Input Form -->
                    <Border Grid.Row="4"
                            Background="#2D2D30"
                            BorderBrush="#3F3F46"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="15">
                        <StackPanel>
                            <!-- Prefix -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="接頭辞:" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="PrefixTextBox" Grid.Column="1" Style="{StaticResource DarkTextBox}"/>
                            </Grid>
         
                            <!-- Sequence + Format -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="連番:" Style="{StaticResource FormLabel}"/>
                                <TextBox x:Name="SequenceTextBox" Grid.Column="1" Style="{StaticResource DarkTextBox}"/>
                                
                                <ComboBox x:Name="DigitsComboBox" Grid.Column="3" Style="{StaticResource DarkComboBox}" Width="65" SelectedIndex="3">
                                    <ComboBoxItem Content="1桁" Foreground="Black" Background="White"/>
                                    <ComboBoxItem Content="2桁" Foreground="Black" Background="White"/>
                                    <ComboBoxItem Content="3桁" Foreground="Black" Background="White"/>
                                    <ComboBoxItem Content="4桁" Foreground="Black" Background="White" IsSelected="True"/>
                                    <ComboBoxItem Content="5桁" Foreground="Black" Background="White"/>
                                    <ComboBoxItem Content="6桁" Foreground="Black" Background="White"/>
                                    <ComboBoxItem Content="日時" Foreground="Black" Background="White"/>
                                </ComboBox>
                                
                                <ComboBox x:Name="FormatComboBox" Grid.Column="5" Style="{StaticResource DarkComboBox}">
                                    <ComboBoxItem Content="JPG" IsSelected="True" Foreground="Black" Background="White"/>
                                    <ComboBoxItem Content="PNG" Foreground="Black" Background="White"/>
                                </ComboBox>
                            </Grid>
        
                            <!-- Filename Preview -->
                            <Border Background="#1E1E1E"
                                    CornerRadius="2"
                                    Padding="8,5"
                                    Margin="0,0,0,10">
                                <TextBlock x:Name="FileNamePreview"
                                           Foreground="#569CD6"
                                           FontFamily="Consolas, Yu Gothic UI"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Text="ファイル名プレビュー"/>
                            </Border>
        
                            <!-- Save Button -->
                            <Button x:Name="SaveButton" 
                                    Style="{StaticResource PrimaryButton}" 
                                    Content="💾 保存 (Enter)" 
                                    IsDefault="True"
                                    Margin="0,0,0,10"
                                    Padding="0,10"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                
                        </Grid>
                    </TabItem>
                    
                    <TabItem Header="🖌️ オーバーレイ" Style="{StaticResource DarkTabItem}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                            <StackPanel>
                                <!-- Master Toggle -->
                                <Border Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4" Padding="15,10" Margin="0,0,0,10">
                                    <CheckBox x:Name="OverlayEnableCheckBox" Content="オーバーレイ機能を有効にする" Style="{StaticResource DarkCheckBox}" FontWeight="Bold" Foreground="#569CD6"/>
                                </Border>

                                <StackPanel x:Name="OverlaySettingsPanel" IsEnabled="{Binding ElementName=OverlayEnableCheckBox, Path=IsChecked}">
                                    <!-- System Info Section -->
                                    <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="システム情報" Foreground="#AAAAAA" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <CheckBox x:Name="EmbedSysInfoCheckBox" Content="画像にシステム情報を埋め込む" Style="{StaticResource DarkCheckBox}" Margin="0,0,0,12"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="表示位置:" Style="{StaticResource FormLabel}"/>
                                                <ComboBox x:Name="SysInfoPositionComboBox" Grid.Column="1" Style="{StaticResource DarkComboBox}">
                                                    <ComboBoxItem Tag="TopLeft" Content="左上"/>
                                                    <ComboBoxItem Tag="TopRight" Content="右上"/>
                                                    <ComboBoxItem Tag="BottomLeft" Content="左下"/>
                                                    <ComboBoxItem Tag="BottomRight" Content="右下"/>
                                                </ComboBox>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Custom Text Section -->
                                    <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="カスタムテキスト" Foreground="#AAAAAA" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="テキスト:" Style="{StaticResource FormLabel}"/>
                                                <TextBox x:Name="OverlayTextBox" Grid.Column="1" Style="{StaticResource DarkTextBox}"/>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="表示位置:" Style="{StaticResource FormLabel}"/>
                                                <ComboBox x:Name="OverlayTextPositionComboBox" Grid.Column="1" Style="{StaticResource DarkComboBox}">
                                                    <ComboBoxItem Tag="TopLeft" Content="左上"/>
                                                    <ComboBoxItem Tag="TopRight" Content="右上"/>
                                                    <ComboBoxItem Tag="BottomLeft" Content="左下"/>
                                                    <ComboBoxItem Tag="BottomRight" Content="右下"/>
                                                </ComboBox>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Update Button -->
                                <Button x:Name="UpdatePreviewButton" 
                                        Style="{StaticResource PrimaryButton}" 
                                        Content="🔄 プレビューを更新" 
                                        Margin="0,0,0,10"
                                        Padding="0,10"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Crop Tab -->
                    <TabItem Header="📐 トリミング" Style="{StaticResource DarkTabItem}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                            <StackPanel>
                                <!-- Master Toggle -->
                                <Border Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4" Padding="15,10" Margin="0,0,0,10">
                                    <CheckBox x:Name="CropEnableCheckBox" Content="トリミング機能を有効にする" Style="{StaticResource DarkCheckBox}" FontWeight="Bold" Foreground="#569CD6"/>
                                </Border>

                                <StackPanel x:Name="CropSettingsPanel" IsEnabled="{Binding ElementName=CropEnableCheckBox, Path=IsChecked}">
                                    <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="切り抜き範囲 (プレビュー上でドラッグして指定可能)" Foreground="#AAAAAA" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12" TextWrapping="Wrap"/>
                                            
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0" Text="X:" Style="{StaticResource FormLabel}"/>
                                                <TextBox x:Name="CropXTextBox" Grid.Column="1" Style="{StaticResource DarkTextBox}"/>
                                                
                                                <TextBlock Grid.Column="3" Text="Y:" Style="{StaticResource FormLabel}"/>
                                                <TextBox x:Name="CropYTextBox" Grid.Column="4" Style="{StaticResource DarkTextBox}"/>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0" Text="幅:" Style="{StaticResource FormLabel}"/>
                                                <TextBox x:Name="CropWidthTextBox" Grid.Column="1" Style="{StaticResource DarkTextBox}"/>
                                                
                                                <TextBlock Grid.Column="3" Text="高さ:" Style="{StaticResource FormLabel}"/>
                                                <TextBox x:Name="CropHeightTextBox" Grid.Column="4" Style="{StaticResource DarkTextBox}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Button x:Name="ResetCropButton" 
                                            Style="{StaticResource SecondaryButton}" 
                                            Content="範囲をリセット" 
                                            Margin="0,0,0,10"
                                            Padding="0,6"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
        </Grid>
    </Grid>
    </Border>
</Window>
